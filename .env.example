# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/book_explorer"

# ─── Google Books API ────────────────────────────────────────
# Optional: leave empty to use the public unauthenticated endpoint
GOOGLE_BOOKS_API_KEY=

# ─── Clerk Auth ──────────────────────────────────────────────
# Frontend (Remix)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Backend JWT verification
CLERK_JWT_KEY=

# ─── API ─────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL=http://localhost:3001

# ─── Web ─────────────────────────────────────────────────────
WEB_PORT=3000
SESSION_SECRET=change_me_in_production
