# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/book_explorer"

# ─── Google Books API ────────────────────────────────────────
# Optional: leave empty to use the public unauthenticated endpoint
GOOGLE_BOOKS_API_KEY=

# ─── Custom JWT Auth ─────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_in_production_use_a_long_random_string

# ─── API ─────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Web ─────────────────────────────────────────────────────
WEB_PORT=3000
# Remix session cookie secret — generate with: openssl rand -base64 64
SESSION_SECRET=change_me_in_production_use_a_long_random_string
