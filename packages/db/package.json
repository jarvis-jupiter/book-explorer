    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1"
  },
  "devDependencies": {
    "prisma": "^6.3.1",
    "typescript": "^5.7.3"
  }
}
